# NoGame Starknet Environment Configuration - Docker/Katana
# This file contains the configuration for deploying to Katana running in Docker

# Katana RPC URL (Docker network)
STARKNET_RPC_URL=http://katana:5050

# Local Katana account material is deterministic development data.
# Replace every placeholder below in your local env file and never reuse
# Katana private keys on public networks.

# Katana Pre-funded Account #0
# These are the default Katana accounts generated with --seed 0
STARKNET_ACCOUNT=katana-0
STARKNET_ACCOUNT_ADDRESS=0x127fd5f1fe78a71f8bcd1fec63e3fe2f0486b6ecd5c86a0466c3a21fa5cfcec
STARKNET_PRIVATE_KEY=<katana-private-key-0>
STARKNET_PUBLIC_KEY=0x33246ce85ebdc292e6a5c5b4dd51fab2757be34b8ffda847ca6925edf31cb67

# Alternative Katana accounts (for testing with multiple players)
# Account #1
STARKNET_ACCOUNT_1=0x13d9ee239f33fea4f8785b9e3870ade909e20a9599ae7cd62c1c292b73af1b7
STARKNET_PRIVATE_KEY_1=<katana-private-key-1>
STARKNET_PUBLIC_KEY_1=0x4c339f18b9d1b95b64a6d378abd1480b2e0d5d5bd33cd0828cbce4d65c27284

# Account #2
STARKNET_ACCOUNT_2=0x17cc6ca902ed4e8baa8463a7009ff18cc294fa85a94b4ce6ac30a9ebd6057c7
STARKNET_PRIVATE_KEY_2=<katana-private-key-2>
STARKNET_PUBLIC_KEY_2=0x16e375df37a7653038bd9eccd767e780c2c4d4c66b4c85f455236a3fd75673a

# Account #3
STARKNET_ACCOUNT_3=0x2af9427c5a277474c079a1283c880ee8a6f0f8fbf73ce969c08d88befec1bba
STARKNET_PRIVATE_KEY_3=<katana-private-key-3>
STARKNET_PUBLIC_KEY_3=0x2b191c2f3ecf685a91af7cf72a43e7b90e2e41220175de5c4f7498981b10053

# Account #4
STARKNET_ACCOUNT_4=0x359b9068eadcaaa449c08b79a367c6fdfba9448c29e96934e3552dab0fdd950
STARKNET_PRIVATE_KEY_4=<katana-private-key-4>
STARKNET_PUBLIC_KEY_4=0x640466ebd2ce505209d3e5c4494b4276ed8f1cde764d757eb48831961f7cdea

# Deployed Contract Addresses (populated by deployment script)
